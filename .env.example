# Copy to .env — NEVER commit .env (see .gitignore + DEPLOYMENT_SECURITY.md)
# Production: set VITE_CONTACT_FORM_ENDPOINT only in Netlify / Vercel dashboard (env vars), not in git.
# Google Apps Script Web App /exec URL (POST JSON) OR your serverless form endpoint.
# Sheet IDs / API keys stay ONLY in env + backend — not in source.
VITE_CONTACT_FORM_ENDPOINT=

# Optional: founder portrait on Home — full URL (Netlify: Site settings → Environment variables).
# Use this if you do NOT commit public/branding/founder-sonu-gurjar.jpg to git.
# Example: https://your-cdn.com/sonu-portrait.jpg
# VITE_FOUNDER_PHOTO_URL=

# Optional: analytics (public key only if vendor allows client-side)
# VITE_PLAUSIBLE_DOMAIN=

# Calendly booking page (optional). If not set, Calendly iframe falls back to calendly.com homepage.
# Example: https://calendly.com/mas-tech/demo
VITE_CALENDLY_URL=

# WhatsApp CTA (optional). If not set, uses wa.me share link (no phone required).
# Example: https://wa.me/919999999999?text=Hi%20MAS%20TECH%2C%20I%20want%20a%20demo
VITE_WHATSAPP_LINK=

# Optional social links
VITE_LINKEDIN_URL=
VITE_INSTAGRAM_URL=

# Feedback Mic + Evolution (Supabase Edge Functions — Paradise project)
# VITE_SUPABASE_URL=https://YOUR_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key
# Dev: hide FAB → VITE_SHOW_FEEDBACK_FAB=false

# Universal Jadu Gateway (/login) — optional overrides (defaults: paradise-app / mis-admin Netlify)
# VITE_JADU_PARADISE_FIELD_URL=https://paradise-app.netlify.app
# VITE_JADU_PARADISE_ADMIN_URL=https://mis-admin.netlify.app

# Supabase Edge (deploy secrets — not VITE): GATEWAY_WEBAUTHN_RP_ID, GATEWAY_WEBAUTHN_RP_NAME, GATEWAY_ADMIN_MFA_WEBHOOK_URL
